  "keyFeatures": [
    "AI agent creation and management with revisions and workflow graphs",
    "Multi-channel conversations: voice, SMS, email, and API",
    "Knowledge base with semantic search, connectors (Notion, Google Drive, S3), and sensitivity classification",
    "Human-in-the-loop approvals and handoffs",
    "Warm call transfer with Twilio bridge numbers",
    "Policy enforcement with LLM judge and expression-based checks",
    "Custom and MCP-based integrations with tool management",
    "Simulation testing with personas, scenarios, and eval suites",
    "Comprehensive analytics across tools, sessions, knowledge, and integrations",
    "PII scrubbing, data retention, and governance controls",
    "Webhook subscriptions and Slack notifications",
    "Model routing with fallback chains"
  ],
